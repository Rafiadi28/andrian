Options -Indexes
ServerSignature Off

# ============================================================
# KEAMANAN: Blokir akses langsung ke file sensitif
# ============================================================
<FilesMatch "\.(sql|log|env|md|txt|ini|sh|bak)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Blokir skrip migrasi & utilitas (Apache 2.4+)
<IfModule mod_authz_core.c>
  <FilesMatch "^(migration_trigger|migrate_agunan_fix|migrate_bank_lain|_add_covernote_col)\.php$">
    Require all denied
  </FilesMatch>
</IfModule>

# Blokir akses ke folder sensitif
<IfModule mod_rewrite.c>
    RewriteEngine On

    # ── HTTPS Redirect (aktifkan setelah SSL Let's Encrypt terpasang di Hostinger) ──
    # RewriteCond %{HTTPS} off
    # RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Blokir folder config, logs, backups, docs
    RewriteRule ^config(/.*)?$  - [F,L]
    RewriteRule ^logs(/.*)?$    - [F,L]
    RewriteRule ^backups(/.*)?$ - [F,L]
    RewriteRule ^docs(/.*)?$    - [F,L]
</IfModule>

# ============================================================
# PHP Settings — Production (Hostinger)
# (Dibungkus IfModule agar tidak menyebabkan Error 500 jika PHP berjalan sebagai FastCGI/LiteSpeed)
# ============================================================
<IfModule mod_php.c>
    php_flag  display_errors        Off
    php_flag  log_errors            On
    php_value error_log             logs/php_error.log
    php_value upload_max_filesize   10M
    php_value post_max_size         12M
    php_value max_execution_time    60
    php_value session.cookie_httponly 1
    php_value session.use_strict_mode 1
</IfModule>
<IfModule mod_php5.c>
    php_flag  display_errors        Off
    php_flag  log_errors            On
    php_value error_log             logs/php_error.log
    php_value upload_max_filesize   10M
    php_value post_max_size         12M
    php_value max_execution_time    60
    php_value session.cookie_httponly 1
    php_value session.use_strict_mode 1
</IfModule>
<IfModule mod_php7.c>
    php_flag  display_errors        Off
    php_flag  log_errors            On
    php_value error_log             logs/php_error.log
    php_value upload_max_filesize   10M
    php_value post_max_size         12M
    php_value max_execution_time    60
    php_value session.cookie_httponly 1
    php_value session.use_strict_mode 1
</IfModule>
